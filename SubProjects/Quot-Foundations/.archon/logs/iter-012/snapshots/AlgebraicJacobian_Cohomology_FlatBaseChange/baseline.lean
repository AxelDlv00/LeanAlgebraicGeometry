    Scheme.Modules.pushforward (Spec.map œÜ) ‚ãô moduleSpecŒìFunctor (R := R) ‚âÖ
      moduleSpecŒìFunctor (R := R') ‚ãô ModuleCat.restrictScalars œÜ.hom :=
