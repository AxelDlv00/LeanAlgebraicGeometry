    (Over.post (X := Ui) (Opens.map œÜ.inv.base)).IsContinuous
      ((Opens.grothendieckTopology X).over Ui)
      ((Opens.grothendieckTopology Y).over (œÜ.inv ‚Åª¬π·µÅ Ui)) :=
