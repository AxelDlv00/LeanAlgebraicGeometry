/-!
# Higher direct images along open immersions of affine opens

This file establishes `lem:open_immersion_pushforward_comp`:

1. `higherDirectImage_openImmersion_acyclic`: for an open immersion `j : U ‚Ü™ X` of an
   affine open `U` into a separated scheme `X`, the higher direct images `R^q j_* H` vanish
   for `q ‚â• 1` and any quasi-coherent `O_U`-module `H`.

2. `higherDirectImage_openImmersion_comp` (pinned declaration): consequently, for any
   morphism `f : X ‚ü∂ S` and quasi-coherent `H` on `U`, there is a canonical isomorphism
   `R^k f_*(j_* H) ‚âÖ R^k (f ‚àò j)_* H`.

Blueprint: `lem:open_immersion_pushforward_comp`.
Source: Stacks Project, Cohomology of Schemes, `lemma-relative-affine-vanishing`.
-/

universe u

open CategoryTheory Limits

/-! ## Project-local Mathlib supplement ‚Äî reflecting `IsZero` through a faithful functor -/

namespace CategoryTheory.Functor

/-- **A faithful functor that preserves zero morphisms reflects the zero object.**
If `F` is faithful and preserves zero morphisms and `F.obj X` is a zero object, then `X`
is a zero object. (Three-line proof off `IsZero.iff_id_eq_zero` + `Functor.map_injective`.)

Project-local Mathlib supplement (category theory).  A copy of the same lemma in
`CechAugmentedResolution.lean`; reproduced here because that sibling file is not in this
file's import chain. -/
lemma isZero_of_faithful_preservesZeroMorphisms
    {C D : Type*} [Category C] [Category D] [Limits.HasZeroMorphisms C] [Limits.HasZeroMorphisms D]
    (F : C ‚•§ D) [F.PreservesZeroMorphisms] [F.Faithful] {Y : C}
    (h : Limits.IsZero (F.obj Y)) : Limits.IsZero Y := by
  rw [Limits.IsZero.iff_id_eq_zero] at h ‚ä¢
  apply F.map_injective
  rw [F.map_id, F.map_zero]
  exact h

end CategoryTheory.Functor

/-! ## Project-local Mathlib supplement ‚Äî sheafification of a sectionwise-locally-zero presheaf -/

namespace CategoryTheory.GrothendieckTopology

open Opposite in
/-- **The sheafification of a presheaf whose sections are locally zero vanishes.**
If for every object `U` and every section `s : Q(U)` there is a covering sieve `S ‚àà J U`
on which `s` restricts to `0`, then the sheafification of `Q` is a zero object.

This is the *sectionwise* (local-injectivity) strengthening of
`isZero_presheafToSheaf_of_locally_isZero`: that lemma requires the *objectwise* vanishing
`Q.obj (op V) = 0` for every member `V` of a single covering sieve, which forces the
vanishing to hold on a downward-closed family.  Here only the restricted *section* need
vanish, so the witnessing sieve can be generated by a cofinal *basis* of "good" opens
(e.g. the affine opens, where the section group vanishes) even though the basis itself is
not downward closed.  The local injectivity of `0 : Q ‚ü∂ Z` (`Z` the constant zero
presheaf) is read off from the hypothesis applied to `x - y`; local surjectivity is free.
Project-local Mathlib supplement (site theory). -/
lemma isZero_presheafToSheaf_of_sections_locally_zero {C : Type*} [Category C]
    (J : GrothendieckTopology C) [HasSheafify J AddCommGrpCat.{u}]
    [J.WEqualsLocallyBijective AddCommGrpCat.{u}]
    {Q : C·µí·µñ ‚•§ AddCommGrpCat.{u}}
    (h : ‚àÄ (U : C) (s : ToType (Q.obj (op U))), ‚àÉ S : Sieve U, S ‚àà J U ‚àß
      ‚àÄ ‚¶ÉV : C‚¶Ñ ‚¶Ég : V ‚ü∂ U‚¶Ñ, S.arrows g ‚Üí (ConcreteCategory.hom (Q.map g.op)) s = 0) :
    IsZero ((presheafToSheaf J AddCommGrpCat.{u}).obj Q) := by
  let Z : C·µí·µñ ‚•§ AddCommGrpCat.{u} := (Functor.const C·µí·µñ).obj (AddCommGrpCat.of PUnit)
  have hZobj : ‚àÄ x : C·µí·µñ, IsZero (Z.obj x) := by
    intro x
    change IsZero (AddCommGrpCat.of PUnit)
    exact AddCommGrpCat.isZero_of_subsingleton _
  have hZ : IsZero Z := (Functor.isZero_iff Z).mpr hZobj
  haveI hli : Presheaf.IsLocallyInjective J (0 : Q ‚ü∂ Z) := by
    refine ‚ü®?_‚ü©
    intro X x y _
    obtain ‚ü®S, hS, hSzero‚ü© := h X.unop (x - y)
    apply J.superset_covering _ hS
    intro V g hg
    change (ConcreteCategory.hom (Q.map g.op)) x = (ConcreteCategory.hom (Q.map g.op)) y
    have h0 : (ConcreteCategory.hom (Q.map g.op)) (x - y) = 0 := hSzero hg
    rw [map_sub] at h0
    exact sub_eq_zero.mp h0
  haveI hls : Presheaf.IsLocallySurjective J (0 : Q ‚ü∂ Z) := by
    refine ‚ü®?_‚ü©
    intro U s
    refine J.superset_covering (fun V g _ => ?_) (J.top_mem U)
    refine ‚ü®0, ?_‚ü©
    haveI : Subsingleton (Z.obj (op V)) := AddCommGrpCat.subsingleton_of_isZero (hZobj (op V))
    exact Subsingleton.elim _ _
  exact isZero_presheafToSheaf_obj_of_isLocallyBijective J (0 : Q ‚ü∂ Z) hZ

end CategoryTheory.GrothendieckTopology

namespace AlgebraicGeometry

open Scheme.Modules

variable {U X S : Scheme.{u}}

/- Planner strategy:
Part (1): `R^q j_* H` is the sheafification of `V ‚Ü¶ H^q(j‚Åª¬πV, H)` (presheaf description
`higher_direct_image_presheaf`, Stacks 01XJ); for affine `V`, `j‚Åª¬πV = U ‚à© V` is affine (U affine,
X separated), so `affine_serre_vanishing` kills `H^q` for `q ‚â• 1`; affine opens are a basis ‚áí
`R^q j_* H = 0`. Part (2): take an injective resolution `H ‚Üí I‚Ä¢`; `j_* I‚Ä¢` is a resolution of
`j_* H` (each `j_* I‚Åø` is `j_*`-acyclic by (1)) and each `j_* I‚Åø` is `f_*`-acyclic (same presheaf
+ Serre-vanishing argument on `U ‚à© f‚Åª¬πV`); so `j_* I‚Ä¢` is an `f_*`-acyclic resolution of `j_* H`,
and the P4 acyclic-resolution comparison (`acyclic_resolution_computes_derived` /
`rightDerivedIsoOfAcyclicResolution`) with `G = f_*` gives `R^k f_*(j_* H) ‚âÖ H^k(f_*(j_* I‚Ä¢)) =
H^k((f‚àòj)_* I‚Ä¢) = R^k (f‚àòj)_* H`, using `f_* ‚àò j_* = (f‚àòj)_*`. Blueprint:
`lem:open_immersion_pushforward_comp`. Source: Stacks `lemma-relative-affine-vanishing`.
-/

/-- **Higher direct images of an affine open immersion vanish** (part (1) of blueprint
`lem:open_immersion_pushforward_comp`; Stacks `lemma-relative-affine-vanishing`).

For an open immersion `j : U ‚Ü™ X` where `U` is affine and `X` is separated, the morphism
`j` is affine (since for any affine open `V ‚äÜ X`, `j‚Åª¬πV = U ‚à© V` is affine by separatedness).
Therefore `R^q j_* H = 0` for every `q ‚â• 1` and every quasi-coherent `O_U`-module `H`.

Proof route: by `higherDirectImage_iso_sheafify_presheafHomology`, `R^q j_* H` is the
sheafification of `V ‚Ü¶ H^q(j‚Åª¬πV, H)`. For affine `V`, `j‚Åª¬πV = U ‚à© V` is affine (`U` affine
+ `X` separated), and `affine_serre_vanishing` kills `H^q` for `q ‚â• 1`. Since affine opens
form a basis, the presheaf homology is locally zero, and the site lemmas
`isZero_presheafToSheaf_obj_of_isLocallyBijective` (in `CechHigherDirectImage.lean`,
importable via `AffineSerreVanishing`) collapse the sheafification to zero. -/
private lemma isAffineHom_of_affine_separated (j : U ‚ü∂ X) [IsAffine U] [X.IsSeparated] :
    IsAffineHom j := by
  have hg : IsSeparated (terminal.from X) := Scheme.IsSeparated.isSeparated_terminal_from
  have hcomp : IsAffineHom (j ‚â´ terminal.from X) := by
    have he : j ‚â´ terminal.from X = terminal.from U := terminal.hom_ext _ _
    rw [he]; infer_instance
  exact IsAffineHom.of_comp j (terminal.from X)

theorem higherDirectImage_openImmersion_acyclic [HasInjectiveResolutions U.Modules]
    (j : U ‚ü∂ X) [IsOpenImmersion j] [IsAffine U] [X.IsSeparated]
    (H : U.Modules) (hH : H.IsQuasicoherent) (q : ‚Ñï) (hq : 0 < q) :
    IsZero (higherDirectImage j q H) := by
  -- `j` is an affine morphism (open immersion of an affine into a separated scheme),
  -- so the preimage of every affine open `V ‚äÜ X` is the affine open `j‚Åª¬πV = U ‚à© V`.
  haveI : IsAffineHom j := isAffineHom_of_affine_separated j
  -- Presheaf description (Stacks 01XJ): `R·µÝ j_* H ‚âÖ sheafify(V ‚Ü¶ H·µÝ((j_* I‚Ä¢)(V)))`
  -- for any injective resolution `I` of `H`. Reduce to the vanishing of that sheafification.
  refine IsZero.of_iso ?_
    (higherDirectImage_iso_sheafify_presheafHomology j q (injectiveResolution H))
  set Œ± : X.ringCatSheaf.obj ‚ü∂ X.ringCatSheaf.obj := ùüô X.ringCatSheaf.obj with hŒ±
  set P := (pushforwardResolutionPresheafComplex j (injectiveResolution H)).homology q with hP
  -- Reflect `IsZero` through the faithful, zero-preserving forgetful functor `toSheaf`.
  apply Functor.isZero_of_faithful_preservesZeroMorphisms (SheafOfModules.toSheaf X.ringCatSheaf)
  -- Transport across the sheafification square
  -- `toSheaf ‚àò sheafification ‚âÖ presheafToSheaf ‚àò toPresheaf`.
  refine IsZero.of_iso ?_ ((PresheafOfModules.sheafificationCompToSheaf Œ±).app P)
  set Q := (PresheafOfModules.toPresheaf X.ringCatSheaf.obj).obj P with hQ
  -- KEY VANISHING (genuine cohomological gap): the presheaf homology `Q` is a *zero object*
  -- over every affine open `W ‚äÜ X`, because `j‚Åª¬πW` is affine (`j` is an affine morphism) and
  -- `affine_serre_vanishing` kills `H·µÝ(j‚Åª¬πW, H)` for `q ‚â• 1`.
  have hSec : ‚àÄ (W : TopologicalSpace.Opens X), IsAffineOpen W ‚Üí
      IsZero (Q.obj (Opposite.op W)) := by
    intro W hW
    -- Evaluate-at-`W` the presheaf complex; this functor preserves homology, so
    -- `Q.obj (op W) ‚âÖ H·µÝ(Œì(W, f_* I‚Ä¢)) = H·µÝ(j‚Åª¬πW, H)`, which vanishes for affine `j‚Åª¬πW`.
    set GW := PresheafOfModules.toPresheaf X.ringCatSheaf.obj ‚ãô
      (evaluation (TopologicalSpace.Opens X)·µí·µñ AddCommGrpCat).obj (Opposite.op W) with hGW
    set Kp := pushforwardResolutionPresheafComplex j (injectiveResolution H) with hKp
    refine IsZero.of_iso ?_ (GW.mapHomologyIso' (ComplexShape.up ‚Ñï) Kp q).symm
    -- The section complex `n ‚Ü¶ Œì(W, f_* I^n) = Œì(j‚Åª¬πW, I^n)` is the image of the chosen
    -- injective resolution of `H` under the additive sections-over-`j‚Åª¬πW` functor `Œ¶`.
    set Œ¶ : U.Modules ‚•§ AddCommGrpCat :=
      Scheme.Modules.pushforward j ‚ãô SheafOfModules.forget X.ringCatSheaf ‚ãô
        PresheafOfModules.restrictScalars Œ± ‚ãô PresheafOfModules.toPresheaf X.ringCatSheaf.obj ‚ãô
        (evaluation (TopologicalSpace.Opens X)·µí·µñ AddCommGrpCat).obj (Opposite.op W) with hŒ¶
    -- Additivity of the 5-fold composite: instance synthesis of the whole composite is costly,
    -- so we discharge `map_add` directly, peeling one (individually additive) functor at a time.
    haveI hpf : (Scheme.Modules.pushforward j).Additive := inferInstance
    haveI hfg : (SheafOfModules.forget X.ringCatSheaf).Additive := inferInstance
    haveI hrs : (PresheafOfModules.restrictScalars Œ±).Additive := inferInstance
    haveI htp : (PresheafOfModules.toPresheaf X.ringCatSheaf.obj).Additive := inferInstance
    haveI hev : ((evaluation (TopologicalSpace.Opens X)·µí·µñ AddCommGrpCat).obj (Opposite.op W)).Additive :=
      inferInstance
    haveI : Œ¶.Additive := by
      rw [hŒ¶]
      refine ‚ü®fun {A B f g} => ?_‚ü©
      simp only [Functor.comp_map]
      rw [Functor.map_add (Scheme.Modules.pushforward j),
        Functor.map_add (SheafOfModules.forget X.ringCatSheaf),
        Functor.map_add (PresheafOfModules.restrictScalars Œ±),
        Functor.map_add (PresheafOfModules.toPresheaf X.ringCatSheaf.obj),
        Functor.map_add ((evaluation (TopologicalSpace.Opens X)·µí·µñ AddCommGrpCat).obj (Opposite.op W))]
    have hcomplex : (GW.mapHomologicalComplex (ComplexShape.up ‚Ñï)).obj Kp
        = (Œ¶.mapHomologicalComplex (ComplexShape.up ‚Ñï)).obj (injectiveResolution H).cocomplex :=
      rfl
    rw [hcomplex]
    -- `isoRightDerivedObj` recognises this homology as the `q`-th right derived sections
    -- functor `R·µÝ Œì(j‚Åª¬πW, -)` applied to `H`, i.e. the absolute cohomology `H·µÝ(j‚Åª¬πW, H)`.
    refine IsZero.of_iso ?_ ((injectiveResolution H).isoRightDerivedObj Œ¶ q).symm
    -- RESIDUAL (Bridge 2): `H·µÝ(j‚Åª¬πW, H) = 0` for `q ‚â• 1`.  `j‚Åª¬πW` is affine (`j` is an
    -- affine morphism), so this is Serre vanishing on the affine `j‚Åª¬πW` (`affine_serre_vanishing`
    -- transported across `j‚Åª¬πW ‚âÖ Spec Œì(j‚Åª¬πW, ùí™)`).
    sorry
  -- Since affine opens form a basis of `X`, every section of `Q` restricts to `0` on the
  -- affine opens contained in its domain, so `Q` is sectionwise locally zero and its
  -- sheafification vanishes.
  apply CategoryTheory.GrothendieckTopology.isZero_presheafToSheaf_of_sections_locally_zero
    (Opens.grothendieckTopology X) (Q := Q)
  intro U s
  refine ‚ü®{ arrows := fun {V} _ => ‚àÉ W : TopologicalSpace.Opens X,
              IsAffineOpen W ‚àß V ‚â§ W ‚àß W ‚â§ U,
            downward_closed := ?_ }, ?_, ?_‚ü©
  ¬∑ rintro V V' g ‚ü®A, hA, hVA, hAU‚ü© h
    exact ‚ü®A, hA, le_trans (leOfHom h) hVA, hAU‚ü©
  ¬∑ -- membership in the opens topology: every point of `U` has an affine basis neighbourhood
    intro x hx
    obtain ‚ü®W, hWmem, hxW, hWU‚ü© :=
      (TopologicalSpace.Opens.isBasis_iff_nbhd.mp (Scheme.isBasis_affineOpens X)) hx
    exact ‚ü®W, homOfLE hWU, ‚ü®W, hWmem, le_refl W, hWU‚ü©, hxW‚ü©
  ¬∑ -- the restriction of `s` to a sieve member `V ‚â§ A ‚â§ U` (with `A` affine) factors through
    -- `Q.obj (op A) = 0`, hence vanishes.
    rintro V g ‚ü®A, hA, hVA, hAU‚ü©
    haveI : Subsingleton (ToType (Q.obj (Opposite.op A))) :=
      AddCommGrpCat.subsingleton_of_isZero (hSec A hA)
    have hgfac : g.op = (homOfLE hAU).op ‚â´ (homOfLE hVA).op := by
      rw [‚Üê op_comp]; congr 1
    rw [hgfac, Q.map_comp, ConcreteCategory.comp_apply,
      Subsingleton.elim ((ConcreteCategory.hom (Q.map (homOfLE hAU).op)) s) 0, map_zero]

/-- **Composition formula for higher direct images across an open immersion** (pinned
declaration; blueprint `lem:open_immersion_pushforward_comp`, part (2); Stacks
`lemma-relative-affine-vanishing`).

Let `j : U ‚Ü™ X` be an open immersion of an affine open `U` into a separated scheme `X`,
and `f : X ‚ü∂ S` any morphism. For every quasi-coherent `O_U`-module `H` and every `k ‚â• 0`:
```
  R^k f_*(j_* H) ‚âÖ R^k (f ‚àò j)_* H.
```
Proof route: choose an injective resolution `H ‚Üí I‚Ä¢` in `U.Modules`; apply `j_*`
degreewise to get an `f_*`-acyclic resolution `j_* I‚Ä¢` of `j_* H`
(`higherDirectImage_openImmersion_acyclic` for `j_*`-acyclicity, extended to
`f_*`-acyclicity via the same Serre-vanishing argument on `U ‚à© f‚Åª¬πV`); then
`Functor.rightDerivedIsoOfAcyclicResolution` with `G = (pushforward f)` and the identity
`(pushforward f) ‚àò (pushforward j) = pushforward (j ‚â´ f)` give the stated isomorphism. -/
theorem higherDirectImage_openImmersion_comp
    [HasInjectiveResolutions X.Modules] [HasInjectiveResolutions U.Modules]
    (j : U ‚ü∂ X) [IsOpenImmersion j] [IsAffine U] [X.IsSeparated]
    (f : X ‚ü∂ S) (H : U.Modules) (hH : H.IsQuasicoherent) (k : ‚Ñï) :
    Nonempty (higherDirectImage f k ((pushforward j).obj H) ‚âÖ
              higherDirectImage (j ‚â´ f) k H) := by
  haveI : IsAffineHom j := isAffineHom_of_affine_separated j
  -- Structural plan (all categorical building blocks below are verified to exist):
  --   ‚Ä¢ `G := Scheme.Modules.pushforward f` is additive and preserves finite limits
  --     (`inferInstance`), so `Functor.rightDerivedIsoOfAcyclicResolution` applies to it.
  --   ‚Ä¢ The pushed-forward injective resolution `K := (pushforward j).mapHomologicalComplex I‚Ä¢`
  --     is a candidate acyclic resolution of `j_* H = (pushforward j).obj H`.
  --   ‚Ä¢ `pushforwardComp j f : pushforward j ‚ãô pushforward f ‚âÖ pushforward (j ‚â´ f)` turns
  --     `H^k(G(K))` into `H^k((j ‚â´ f)_* I‚Ä¢) = R^k (j ‚â´ f)_* H`.
  -- RESIDUAL (genuine cohomological gaps, handed off ‚Äî each depends on Part (1)'s residual):
  --   (a) `K` is exact in positive degrees and resolves `j_* H` (i.e. `j_* I‚Ä¢` is a
  --       resolution of `j_* H`) ‚Äî this is `j_*`-acyclicity, the content of
  --       `higherDirectImage_openImmersion_acyclic` applied to each `I‚Åø` and to `H`.
  --   (b) each term `(pushforward j).obj (I‚Åø)` is `(pushforward f)`-acyclic
  --       (`Functor.IsRightAcyclic`), i.e. `R^k f_*(j_* I‚Åø) = 0` for `k ‚â• 1` ‚Äî the same
  --       Serre-vanishing argument on the affine `U ‚à© f‚Åª¬πV` (generalises Part (1) from
  --       `j_*` to `f_*` via the presheaf description on `f‚Åª¬πV`).
  -- Then `Functor.rightDerivedIsoOfAcyclicResolution (pushforward f) K (j_* H) e (a) k`
  -- composed with the `pushforwardComp` transport gives the stated iso.
  sorry

end AlgebraicGeometry
