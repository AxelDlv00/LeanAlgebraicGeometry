attribute [local instance] hasExtModules

variable {U X S : Scheme.{u}}

/-! ## Project-local Mathlib supplement вҖ” corepresentability of the sections functor

The sections functor `О“(V, -)` on `X.Modules` is corepresented by the Form-B object
`jShriekOU V`.  Consequently its right derived functors agree, degreewise, with those of the
Hom-functor `Hom(jShriekOU V, -)` вҖ” the homological half of the identification
`Rбө  О“(V, -) вү… Ext^q(jShriekOU V, -)` (the deep "Bridge (1)/(2)" connecting the higher-direct-image
presheaf homology to absolute cohomology). -/

/-- **Naturality of `jShriekOU_homEquiv` in the coefficient sheaf** (reproduced here; the version
in `AbsoluteCohomology.lean` is `private`). Composing a map `jShriekOU V вҹ¶ FвӮҒ` with `g : FвӮҒ вҹ¶ FвӮӮ`
corresponds, under corepresentability, to applying `g` on sections over `V`. -/
private lemma jShriekOU_homEquiv_nat (V : TopologicalSpace.Opens X)
    {FвӮҒ FвӮӮ : X.Modules} (h : jShriekOU V вҹ¶ FвӮҒ) (g : FвӮҒ вҹ¶ FвӮӮ) :
    jShriekOU_homEquiv V FвӮӮ (h вү« g)
      = (ConcreteCategory.hom (((Scheme.Modules.toPresheafOfModules X).map g).app (op V)))
          (jShriekOU_homEquiv V FвӮҒ h) := by
  have hs : sheafificationHomAddEquiv V FвӮӮ (h вү« g)
        = sheafificationHomAddEquiv V FвӮҒ h вү« (Scheme.Modules.toPresheafOfModules X).map g :=
      (PresheafOfModules.sheafificationAdjunction
        (рқҹҷ X.ringCatSheaf.obj)).homEquiv_naturality_right h g
  change freeYonedaHomEquiv V _ (sheafificationHomAddEquiv V FвӮӮ (h вү« g)) = _
  rw [hs, freeYonedaHomEquiv_apply, PresheafOfModules.comp_app, ModuleCat.comp_apply]
  rfl

/-- `Scheme.Modules.toPresheafOfModules X` is additive (it is the additive composite
`forget вӢҷ restrictScalars (рқҹҷ)`). Project-local instance so `sectionsFunctor` is additive. -/
noncomputable instance toPresheafOfModules_additive :
    (Scheme.Modules.toPresheafOfModules X).Additive :=
  inferInstanceAs (SheafOfModules.forget X.ringCatSheaf вӢҷ
    PresheafOfModules.restrictScalars (рқҹҷ X.ringCatSheaf.obj)).Additive

/-- The sections functor `О“(V,-) : X.Modules вҘӨ Ab` is additive. Project-local instance (the flat
triple composite does not infer additivity automatically). -/
noncomputable instance sectionsFunctor_additive (V : TopologicalSpace.Opens X) :
    (AlgebraicGeometry.sectionsFunctor V).Additive := by
  unfold AlgebraicGeometry.sectionsFunctor
  haveI i2 : (PresheafOfModules.toPresheaf X.ringCatSheaf.obj вӢҷ
      (evaluation (TopologicalSpace.Opens X)бө’бө– AddCommGrpCat).obj (op V)).Additive :=
    Functor.instAdditiveComp _ _
  exact Functor.instAdditiveComp _ _

/-- **The sections functor `О“(V,-)` is corepresented by `jShriekOU V`.** A natural isomorphism
`sectionsFunctor V вү… preadditiveCoyoneda.obj (op (jShriekOU V))`, assembled from the additive
corepresentability bijection `jShriekOU_homEquiv` and its naturality. Project-local: the functorial
upgrade of `jShriekOU_homEquiv`, the geometric input to the absolute-cohomology bridge. -/
noncomputable def sectionsFunctorCorepIso (V : TopologicalSpace.Opens X) :
    AlgebraicGeometry.sectionsFunctor V вү… preadditiveCoyoneda.obj (op (jShriekOU V)) :=
  NatIso.ofComponents
    (fun F => (AddEquiv.toAddCommGrpIso (jShriekOU_homEquiv V F)).symm)
    (by
      intro FвӮҒ FвӮӮ g
      ext s
      simp only [AddEquiv.toAddCommGrpIso, comp_apply, Iso.symm_hom, AddCommGrpCat.hom_ofHom,
        AddEquiv.coe_toAddMonoidHom]
      rw [AddEquiv.symm_apply_eq]
      change (ConcreteCategory.hom ((AlgebraicGeometry.sectionsFunctor V).map g)) s
        = jShriekOU_homEquiv V FвӮӮ ((jShriekOU_homEquiv V FвӮҒ).symm s вү« g)
      rw [jShriekOU_homEquiv_nat V ((jShriekOU_homEquiv V FвӮҒ).symm s) g, AddEquiv.apply_symm_apply]
      rfl)

/-- **Right derived functors transport along a natural isomorphism of additive functors.**
Project-local: assembled from `NatTrans.rightDerived` of `П„.hom`/`П„.inv` and functoriality
(`NatTrans.rightDerived_comp`, `NatTrans.rightDerived_id`). -/
noncomputable def rightDerivedNatIso {C D : Type*} [Category C] [Category D] [Abelian C]
    [HasInjectiveResolutions C] [Abelian D] {F G : C вҘӨ D} [F.Additive] [G.Additive]
    (П„ : F вү… G) (n : в„•) : F.rightDerived n вү… G.rightDerived n where
  hom := NatTrans.rightDerived П„.hom n
  inv := NatTrans.rightDerived П„.inv n
  hom_inv_id := by rw [вҶҗ NatTrans.rightDerived_comp, П„.hom_inv_id, NatTrans.rightDerived_id]
  inv_hom_id := by rw [вҶҗ NatTrans.rightDerived_comp, П„.inv_hom_id, NatTrans.rightDerived_id]

/-! ## Project-local Mathlib supplement вҖ” `Ext` transport along the spectrum equivalence (Need #1)

The whole-scheme spectrum isomorphism `U вү… Spec О“(U,рқ’Ә)` (`Scheme.isoSpec`, a genuine iso because
`U` is affine) induces an *equivalence* of module categories `U.Modules вүҢ (Spec О“ U).Modules`,
assembled from `Scheme.Modules.pushforward` along the iso and its coherences. An equivalence functor
is fully faithful, exact, and preserves injective objects, so
`Functor.mapExt_bijective_of_preservesInjectiveObjects` upgrades `Ext.mapExactFunctor` along it
to an *isomorphism* of `Ext`-groups. This transports the residual general-affine-open Serre
vanishing for `U` to the `Spec`-developed `affine_serre_vanishing_general_open`.

The pushforward-of-an-iso construction is generic in the scheme isomorphism `ПҶ : X вү… Y`. -/

/-- **A scheme isomorphism induces an equivalence of module categories.** For `ПҶ : X вү… Y`, the
pushforward `Scheme.Modules.pushforward ПҶ.hom` is an equivalence with quasi-inverse the pushforward
along `ПҶ.inv`; the unit/counit are supplied by the
`pushforwardId`/`pushforwardComp`/`pushforwardCongr` coherences. Project-local: Mathlib packages the
pushforward functor and its coherences but not the equivalence assembled from an iso (the genuine
equivalence used to transport `Ext` for Need #1). -/
noncomputable def Scheme.Modules.pushforwardEquivOfIso {X Y : Scheme.{u}} (ПҶ : X вү… Y) :
    X.Modules вүҢ Y.Modules :=
  CategoryTheory.Equivalence.mk
    (Scheme.Modules.pushforward ПҶ.hom) (Scheme.Modules.pushforward ПҶ.inv)
    ((Scheme.Modules.pushforwardId X).symm вүӘвү« Scheme.Modules.pushforwardCongr ПҶ.hom_inv_id.symm вүӘвү«
      (Scheme.Modules.pushforwardComp ПҶ.hom ПҶ.inv).symm)
    (Scheme.Modules.pushforwardComp ПҶ.inv ПҶ.hom вүӘвү« Scheme.Modules.pushforwardCongr ПҶ.inv_hom_id вүӘвү«
      Scheme.Modules.pushforwardId Y)

/-- The functor of `pushforwardEquivOfIso ПҶ` is (defeq) the additive `pushforward ПҶ.hom`. -/
noncomputable instance pushforwardEquivOfIso_functor_additive {X Y : Scheme.{u}} (ПҶ : X вү… Y) :
    (Scheme.Modules.pushforwardEquivOfIso ПҶ).functor.Additive :=
  inferInstanceAs (Scheme.Modules.pushforward ПҶ.hom).Additive

/-- **`Ext` transport along a scheme isomorphism.** For `ПҶ : X вү… Y` and `A B : X.Modules`, the
equivalence `pushforwardEquivOfIso ПҶ` (whose functor is fully faithful, exact, and injective-object
preserving) upgrades the additive map `Ext.mapExactFunctor` to an isomorphism of `Ext`-groups
`Ext A B n вүғ+ Ext (ПҶ_* A) (ПҶ_* B) n`, via `Functor.mapExt_bijective_of_preservesInjectiveObjects`.
Project-local: the `Ext`-isomorphism half of Need #1 (the spectrum-equivalence transport). -/
noncomputable def Scheme.Modules.pushforwardExtAddEquiv {X Y : Scheme.{u}} (ПҶ : X вү… Y)
    [EnoughInjectives X.Modules] (A B : X.Modules) (n : в„•) :
    CategoryTheory.Abelian.Ext A B n вүғ+
      CategoryTheory.Abelian.Ext ((Scheme.Modules.pushforwardEquivOfIso ПҶ).functor.obj A)
        ((Scheme.Modules.pushforwardEquivOfIso ПҶ).functor.obj B) n :=
  AddEquiv.ofBijective ((Scheme.Modules.pushforwardEquivOfIso ПҶ).functor.mapExtAddHom A B n)
    (Functor.mapExt_bijective_of_preservesInjectiveObjects
      (Scheme.Modules.pushforwardEquivOfIso ПҶ).functor A B n)

/-- **Need #1 вҖ” `Ext` transport along the whole-scheme spectrum equivalence.** For an affine scheme
`U`, the canonical iso `U вү… Spec О“(U,рқ’Ә)` (`Scheme.isoSpec`) induces, for every `q`, an isomorphism
`Ext^q_U(A, B) вү… Ext^q_{Spec О“ U}(ПҶ_* A, ПҶ_* B)`. In particular the residual `Ext` over `U` vanishes
iff its transport over `Spec О“ U` does. Project-local target of `lem:modules_isoSpec_ext_transport`.

The remaining identification of the transported arguments вҖ” `ПҶ_*(jShriekOU V) вү… jShriekOU V'` for
`V'` the (affine) image open, and quasi-coherence of `ПҶ_* H` вҖ” is handed off (see the task-result
file); it is orthogonal to this transport and is the geometric naturality of `j_!` under a scheme
iso. -/
noncomputable def modulesIsoSpecExtTransport (U : Scheme.{u}) [IsAffine U]
    [EnoughInjectives U.Modules] (A B : U.Modules) (n : в„•) :
    CategoryTheory.Abelian.Ext A B n вүғ+
      CategoryTheory.Abelian.Ext
        ((Scheme.Modules.pushforwardEquivOfIso U.isoSpec).functor.obj A)
        ((Scheme.Modules.pushforwardEquivOfIso U.isoSpec).functor.obj B) n :=
  Scheme.Modules.pushforwardExtAddEquiv U.isoSpec A B n

/-! ## Project-local Mathlib supplement вҖ” `Ext`-vanishing вҹ№ coyoneda right-derived vanishing

The homological-algebra half of the relative-affine vanishing argument (Bridge (1)/(2) remainder).
The `q`-th right derived functor of the additive Hom-functor `Hom(P,-) = preadditiveCoyoneda(op P)`,
evaluated at `H`, is computed (via the chosen injective resolution `IвҖў` of `H`,
`InjectiveResolution.isoRightDerivedObj`) as the homology at degree `q` of the cochain complex of
abelian groups `n вҶҰ (P вҹ¶ IвҒҝ)`.  By `InjectiveResolution.extMk` / `extMk_eq_zero_iff`, that homology
*is* `Ext P H q`: a degree-`q` cocycle is a map `f : P вҹ¶ Iq` with `f вү« d = 0`, and it is a coboundary
iff the class `extMk f` vanishes in `Ext`.  Hence if every class of `Ext P H q` vanishes (`q вүҘ 1`),
the Hom-complex is exact at `q` and the right-derived object is a zero object.  Project-local: Mathlib's
`Ext` is built on the derived category, not on `Functor.rightDerived`, so this bridge is absent. -/

/-- The differential of the Hom-cochain-complex `n вҶҰ (P вҹ¶ IвҒҝ)` (the image of a cochain complex `K`
under `preadditiveCoyoneda(op P)`) acts by post-composition with the differential of `K`. -/
private lemma preadditiveCoyoneda_mapHomologicalComplex_d_apply {C : Type*} [Category C]
    [Preadditive C] (P : C) (K : CochainComplex C в„•) (i j : в„•) (g : P вҹ¶ K.X i) :
    (((preadditiveCoyoneda.obj (op P)).mapHomologicalComplex (ComplexShape.up в„•)).obj K).d i j g
      = g вү« K.d i j := by
  rw [Functor.mapHomologicalComplex_obj_d]
  rfl

/-- **`Ext`-vanishing forces the coyoneda right-derived object to vanish.** If every class of
`Ext P H q` is zero (`q вүҘ 1`), then `(Hom(P,-)).rightDerived q` is a zero object at `H`. The
homological-algebra bridge between the project's `Ext`-based Serre vanishing and the
`Functor.rightDerived` description of the higher-direct-image presheaf homology. Project-local. -/
lemma isZero_coyoneda_rightDerived_of_forall_ext_eq_zero {C : Type*} [Category C]
    [Abelian C] [HasInjectiveResolutions C] [CategoryTheory.HasExt C] (P H : C) (q : в„•) (hq : 0 < q)
    (hExt : вҲҖ e : CategoryTheory.Abelian.Ext P H q, e = 0) :
    IsZero (((preadditiveCoyoneda.obj (op P)).rightDerived q).obj H) := by
  obtain вҹЁp, rflвҹ© := Nat.exists_eq_succ_of_ne_zero hq.ne'
  refine IsZero.of_iso ?_ ((injectiveResolution H).isoRightDerivedObj
    (preadditiveCoyoneda.obj (op P)) (p + 1))
  set R := injectiveResolution H with hR
  refine HomologicalComplex.ExactAt.isZero_homology ?_
  rw [HomologicalComplex.exactAt_iff' _ p (p + 1) (p + 2) (by simp) (by simp),
    ShortComplex.ab_exact_iff]
  intro xвӮӮ hxвӮӮ
  have hf : xвӮӮ вү« R.cocomplex.d (p + 1) (p + 2) = 0 := by
    rw [вҶҗ preadditiveCoyoneda_mapHomologicalComplex_d_apply P R.cocomplex (p + 1) (p + 2) xвӮӮ]
    exact hxвӮӮ
  obtain вҹЁg, hgвҹ© := (R.extMk_eq_zero_iff xвӮӮ (p + 2) rfl hf p rfl).mp (hExt _)
  refine вҹЁg, ?_вҹ©
  rw [вҶҗ hg]
  exact preadditiveCoyoneda_mapHomologicalComplex_d_apply P R.cocomplex p (p + 1) g

/-- **`[HasInjectiveResolutions C]` provides enough injectives.** The degree-`0` term of the chosen
injective resolution, with its quasi-iso unit, is an injective presentation. Project-local connector
(Mathlib derives `HasInjectiveResolutions` from `EnoughInjectives` + `Abelian`, not conversely);
needed to feed `[EnoughInjectives U.Modules]` to the spectrum `Ext`-transport from
`[HasInjectiveResolutions U.Modules]`. -/
lemma enoughInjectives_of_hasInjectiveResolutions {C : Type*} [Category C] [Abelian C]
    [HasInjectiveResolutions C] : EnoughInjectives C where
  presentation X := by
    obtain вҹЁRвҹ© := (HasInjectiveResolutions.out X).out
    exact вҹЁ{ J := R.cocomplex.X 0, injective := R.injective 0, f := R.О№.f 0
             mono := CategoryTheory.InjectiveResolution.instMonoFNatО№ R 0 }вҹ©

/-- **An isomorphism in the first `Ext`-argument transfers subsingletons.** If `Ext B Y q` is a
subsingleton and `ПҶ : A вү… B`, then so is `Ext A Y q` (every class is the `ПҶ.hom`-precomposite of its
`ПҶ.inv`-precomposite, which vanishes). Project-local: the contravariant `Ext`-functoriality packaged
for the Serre-vanishing transport along the `jShriekOU` transport iso. -/
lemma subsingleton_ext_of_iso_fst {C : Type*} [Category C] [Abelian C] [CategoryTheory.HasExt C]
    {A B : C} (ПҶ : A вү… B) (Y : C) (q : в„•)
    [Subsingleton (CategoryTheory.Abelian.Ext B Y q)] :
    Subsingleton (CategoryTheory.Abelian.Ext A Y q) := by
  refine вҹЁfun a b => ?_вҹ©
  suffices h : вҲҖ z : CategoryTheory.Abelian.Ext A Y q, z = 0 by rw [h a, h b]
  intro z
  have hw : (Abelian.Ext.mkвӮҖ ПҶ.inv).comp z (zero_add q) = 0 := Subsingleton.elim _ _
  have hz : z = (Abelian.Ext.mkвӮҖ ПҶ.hom).comp
      ((Abelian.Ext.mkвӮҖ ПҶ.inv).comp z (zero_add q)) (zero_add q) := by
    rw [Abelian.Ext.mkвӮҖ_comp_mkвӮҖ_assoc, ПҶ.hom_inv_id, Abelian.Ext.mkвӮҖ_id_comp]
  rw [hz, hw, Abelian.Ext.comp_zero]

/-- **Serre `Ext`-vanishing over an affine scheme via the spectrum transport.** Let `U` be a scheme,
`ПҶ : U вү… Spec R` a scheme isomorphism, `V вҠҶ U` an open and `H` an `рқ’Ә_U`-module.  If the pushforward
`ОҰ(j_!рқ’Ә_V)` of the corepresenting object is isomorphic to `j_!рқ’Ә_{V'}` for an *affine* open
`V' вҠҶ Spec R`, and `ОҰ H` is quasi-coherent, then every class of `Ext^q_U(j_!рқ’Ә_V, H)` vanishes for
`q вүҘ 1`.  Assembled from `pushforwardExtAddEquiv` (the spectrum transport), the contravariant
`Ext`-transfer `subsingleton_ext_of_iso_fst`, and the now-unconditional
`affine_serre_vanishing_general_open` on `Spec R`.  Project-local: the Bridge (2) Serre-vanishing
leaf of the open-immersion acyclicity, parameterized over the geometric transport data so that the
residual `jShriekOU`/quasi-coherence transport sub-lemmas are isolated. -/
lemma ext_jShriekOU_eq_zero_of_specIso {R : CommRingCat.{u}} (U : Scheme.{u})
    [HasInjectiveResolutions U.Modules] (ПҶ : U вү… Spec R) (V : U.Opens) (H : U.Modules)
    (q : в„•) (hq : 0 < q) (V' : (Spec R).Opens) (hV' : IsAffineOpen V')
    (hjt : (Scheme.Modules.pushforwardEquivOfIso ПҶ).functor.obj (jShriekOU V) вү… jShriekOU V')
    (hqc : ((Scheme.Modules.pushforwardEquivOfIso ПҶ).functor.obj H).IsQuasicoherent)
    (e : Abelian.Ext (jShriekOU V) H q) : e = 0 := by
  haveI : EnoughInjectives U.Modules := enoughInjectives_of_hasInjectiveResolutions
  set ОҰ := Scheme.Modules.pushforwardEquivOfIso ПҶ with hОҰ
  haveI : EnoughInjectives (Spec R).Modules := EnoughInjectives.of_equivalence ОҰ.inverse
  haveI : (ОҰ.functor.obj H).IsQuasicoherent := hqc
  haveI hsub0 : Subsingleton (Abelian.Ext (jShriekOU V') (ОҰ.functor.obj H) q) :=
    вҹЁfun a b => (affine_serre_vanishing_general_open _ V' hV' q hq a).trans
      (affine_serre_vanishing_general_open _ V' hV' q hq b).symmвҹ©
