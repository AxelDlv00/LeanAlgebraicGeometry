-- Heartbeat bumps: the per-slice presentation transport triggers synthesis of the sliced/doubly
-- sliced `HasSheafify`/`WEqualsLocallyBijective`/`HasSheafCompose` instances over `(gt Y).over Vбөў`,
-- whose default-heartbeat search times out (it succeeds when bumped).
/-- **Pushforward along a scheme iso preserves quasi-coherence** (blueprint
`lem:pushforward_iso_preserves_qcoh`; Need #1 `hqc`).  Quasi-coherence is local: move each local
presentation of `H` (over the cover member `Uбөў`) across the colimit-preserving pullback
`pullback ПҲ_r`, then across the comparison iso `pushforwardSlicePullbackIso` to a presentation of
`(ОҰ H).over Vбөў`; conclude per-slice quasi-coherence and glue via
`pushforward_iso_qcoh_of_slice_qcoh`. -/
lemma pushforward_iso_preserves_qcoh {X Y : Scheme.{u}} (ПҶ : X вү… Y) (H : X.Modules)
    (hH : H.IsQuasicoherent) :
    ((Scheme.Modules.pushforwardEquivOfIso ПҶ).functor.obj H).IsQuasicoherent := by
  obtain вҹЁqcdвҹ© := hH.nonempty_quasicoherentData
  refine pushforward_iso_qcoh_of_slice_qcoh ПҶ H qcd (fun i => ?_)
  -- Per-slice: build a presentation of `(ОҰ H).over (ПҶ.invвҒ»В№бөҒ qcd.X i)`.
  haveI hFinal : (sliceOversEquiv ПҶ (qcd.X i)).functor.Final := inferInstance
  -- the unit comparison `О· : (pullback ПҲ_r).obj (unit) вү… unit` (iso since the slice functor is Final).
  have О· : (SheafOfModules.pullback.{u} (sliceStructureSheafHom ПҶ (qcd.X i))).obj
        (SheafOfModules.unit (X.ringCatSheaf.over (qcd.X i))) вү…
      SheafOfModules.unit (Y.ringCatSheaf.over (ПҶ.inv вҒ»В№бөҒ qcd.X i)) :=
    asIso (SheafOfModules.pullbackObjUnitToUnit.{u} (sliceStructureSheafHom ПҶ (qcd.X i)))
  -- transport the local presentation of `H.over Uбөў` across the colimit-preserving pullback...
  have P1 : ((SheafOfModules.pullback.{u} (sliceStructureSheafHom ПҶ (qcd.X i))).obj
      (H.over (qcd.X i))).Presentation :=
    (qcd.presentation i).map (SheafOfModules.pullback.{u} (sliceStructureSheafHom ПҶ (qcd.X i))) О·
  -- ...then across the comparison iso to a presentation of `(ОҰ H).over Vбөў`, whence quasi-coherence.
  exact (P1.ofIsIso (pushforwardSlicePullbackIso ПҶ (qcd.X i) H).hom).isQuasicoherent

end SliceTwoAdj

/- Planner strategy:
Part (1): `R^q j_* H` is the sheafification of `V вҶҰ H^q(jвҒ»В№V, H)` (presheaf description
`higher_direct_image_presheaf`, Stacks 01XJ); for affine `V`, `jвҒ»В№V = U вҲ© V` is affine (U affine,
X separated), so `affine_serre_vanishing` kills `H^q` for `q вүҘ 1`; affine opens are a basis вҮ’
`R^q j_* H = 0`. Part (2): take an injective resolution `H вҶ’ IвҖў`; `j_* IвҖў` is a resolution of
`j_* H` (each `j_* IвҒҝ` is `j_*`-acyclic by (1)) and each `j_* IвҒҝ` is `f_*`-acyclic (same presheaf
+ Serre-vanishing argument on `U вҲ© fвҒ»В№V`); so `j_* IвҖў` is an `f_*`-acyclic resolution of `j_* H`,
and the P4 acyclic-resolution comparison (`acyclic_resolution_computes_derived` /
`rightDerivedIsoOfAcyclicResolution`) with `G = f_*` gives `R^k f_*(j_* H) вү… H^k(f_*(j_* IвҖў)) =
H^k((fвҲҳj)_* IвҖў) = R^k (fвҲҳj)_* H`, using `f_* вҲҳ j_* = (fвҲҳj)_*`. Blueprint:
`lem:open_immersion_pushforward_comp`. Source: Stacks `lemma-relative-affine-vanishing`.
-/

/-- **Higher direct images of an affine open immersion vanish** (part (1) of blueprint
`lem:open_immersion_pushforward_comp`; Stacks `lemma-relative-affine-vanishing`).

For an open immersion `j : U вҶӘ X` where `U` is affine and `X` is separated, the morphism
`j` is affine (since for any affine open `V вҠҶ X`, `jвҒ»В№V = U вҲ© V` is affine by separatedness).
Therefore `R^q j_* H = 0` for every `q вүҘ 1` and every quasi-coherent `O_U`-module `H`.

Proof route: by `higherDirectImage_iso_sheafify_presheafHomology`, `R^q j_* H` is the
sheafification of `V вҶҰ H^q(jвҒ»В№V, H)`. For affine `V`, `jвҒ»В№V = U вҲ© V` is affine (`U` affine
+ `X` separated), and `affine_serre_vanishing` kills `H^q` for `q вүҘ 1`. Since affine opens
form a basis, the presheaf homology is locally zero, and the site lemmas
`isZero_presheafToSheaf_obj_of_isLocallyBijective` (in `CechHigherDirectImage.lean`,
importable via `AffineSerreVanishing`) collapse the sheafification to zero. -/
private lemma isAffineHom_of_affine_separated (j : U вҹ¶ X) [IsAffine U] [X.IsSeparated] :
    IsAffineHom j := by
  have hg : IsSeparated (terminal.from X) := Scheme.IsSeparated.isSeparated_terminal_from
  have hcomp : IsAffineHom (j вү« terminal.from X) := by
    have he : j вү« terminal.from X = terminal.from U := terminal.hom_ext _ _
    rw [he]; infer_instance
  exact IsAffineHom.of_comp j (terminal.from X)

/-- The sections-over-`jвҒ»В№W` functor on `U`-modules, `M вҶҰ О“(W, j_* M) = О“(jвҒ»В№W, M)`,
realised as the composite `pushforward j вӢҷ forget вӢҷ restrictScalars рқҹҷ вӢҷ toPresheaf вӢҷ eval(W)`.
Its `q`-th right derived functor applied to `H` is the absolute cohomology `Hбө (jвҒ»В№W, H)`.
Project-local: a named composite so its additivity instance is synthesised once at the top
level (the 5-fold composite defeats in-proof instance search). -/
noncomputable def pushforwardSectionsFunctor (j : U вҹ¶ X) (W : TopologicalSpace.Opens X) :
    U.Modules вҘӨ AddCommGrpCat :=
  Scheme.Modules.pushforward j вӢҷ SheafOfModules.forget X.ringCatSheaf вӢҷ
    PresheafOfModules.restrictScalars (рқҹҷ X.ringCatSheaf.obj) вӢҷ
    PresheafOfModules.toPresheaf X.ringCatSheaf.obj вӢҷ
    (evaluation (TopologicalSpace.Opens X)бө’бө– AddCommGrpCat).obj (Opposite.op W)

noncomputable instance pushforwardSectionsFunctor_additive
    (j : U вҹ¶ X) (W : TopologicalSpace.Opens X) : (pushforwardSectionsFunctor j W).Additive := by
  unfold pushforwardSectionsFunctor
  -- The flat 5-fold composite defeats instance search; build it as an explicit `instAdditiveComp`
  -- chain (every individual factor is additive).
  haveI hpf : (Scheme.Modules.pushforward j).Additive := inferInstance
  haveI i4 : (PresheafOfModules.toPresheaf X.ringCatSheaf.obj вӢҷ
      (evaluation (TopologicalSpace.Opens X)бө’бө– AddCommGrpCat).obj (Opposite.op W)).Additive :=
    Functor.instAdditiveComp _ _
  haveI i3 : (PresheafOfModules.restrictScalars (рқҹҷ X.ringCatSheaf.obj) вӢҷ
      PresheafOfModules.toPresheaf X.ringCatSheaf.obj вӢҷ
      (evaluation (TopologicalSpace.Opens X)бө’бө– AddCommGrpCat).obj (Opposite.op W)).Additive :=
    Functor.instAdditiveComp _ _
  haveI i2 : (SheafOfModules.forget X.ringCatSheaf вӢҷ
      PresheafOfModules.restrictScalars (рқҹҷ X.ringCatSheaf.obj) вӢҷ
      PresheafOfModules.toPresheaf X.ringCatSheaf.obj вӢҷ
      (evaluation (TopologicalSpace.Opens X)бө’бө– AddCommGrpCat).obj (Opposite.op W)).Additive :=
    Functor.instAdditiveComp _ _
  -- Instance search will not pick up `i2` automatically here, so we pass it explicitly.
  exact @CategoryTheory.Functor.instAdditiveComp _ _ _ _ _ _
    (Scheme.Modules.pushforward j) hpf _ _ _ _ i2

theorem higherDirectImage_openImmersion_acyclic [HasInjectiveResolutions U.Modules]
    (j : U вҹ¶ X) [IsOpenImmersion j] [IsAffine U] [X.IsSeparated]
    (H : U.Modules) (hH : H.IsQuasicoherent) (q : в„•) (hq : 0 < q) :
    IsZero (higherDirectImage j q H) := by
  -- `j` is an affine morphism (open immersion of an affine into a separated scheme),
  -- so the preimage of every affine open `V вҠҶ X` is the affine open `jвҒ»В№V = U вҲ© V`.
  haveI : IsAffineHom j := isAffineHom_of_affine_separated j
  -- Presheaf description (Stacks 01XJ): `Rбө  j_* H вү… sheafify(V вҶҰ Hбө ((j_* IвҖў)(V)))`
  -- for any injective resolution `I` of `H`. Reduce to the vanishing of that sheafification.
  refine IsZero.of_iso ?_
    (higherDirectImage_iso_sheafify_presheafHomology j q (injectiveResolution H))
  set Оұ : X.ringCatSheaf.obj вҹ¶ X.ringCatSheaf.obj := рқҹҷ X.ringCatSheaf.obj with hОұ
  set P := (pushforwardResolutionPresheafComplex j (injectiveResolution H)).homology q with hP
  -- Reflect `IsZero` through the faithful, zero-preserving forgetful functor `toSheaf`.
  apply Functor.isZero_of_faithful_preservesZeroMorphisms (SheafOfModules.toSheaf X.ringCatSheaf)
  -- Transport across the sheafification square
  -- `toSheaf вҲҳ sheafification вү… presheafToSheaf вҲҳ toPresheaf`.
  refine IsZero.of_iso ?_ ((PresheafOfModules.sheafificationCompToSheaf Оұ).app P)
  set Q := (PresheafOfModules.toPresheaf X.ringCatSheaf.obj).obj P with hQ
  -- KEY VANISHING (genuine cohomological gap): the presheaf homology `Q` is a *zero object*
  -- over every affine open `W вҠҶ X`, because `jвҒ»В№W` is affine (`j` is an affine morphism) and
  -- `affine_serre_vanishing` kills `Hбө (jвҒ»В№W, H)` for `q вүҘ 1`.
  have hSec : вҲҖ (W : TopologicalSpace.Opens X), IsAffineOpen W вҶ’
      IsZero (Q.obj (Opposite.op W)) := by
    intro W hW
    -- Evaluate-at-`W` the presheaf complex; this functor preserves homology, so
    -- `Q.obj (op W) вү… Hбө (О“(W, f_* IвҖў)) = Hбө (jвҒ»В№W, H)`, which vanishes for affine `jвҒ»В№W`.
    set GW := PresheafOfModules.toPresheaf X.ringCatSheaf.obj вӢҷ
      (evaluation (TopologicalSpace.Opens X)бө’бө– AddCommGrpCat).obj (Opposite.op W) with hGW
    set Kp := pushforwardResolutionPresheafComplex j (injectiveResolution H) with hKp
    refine IsZero.of_iso ?_ (GW.mapHomologyIso' (ComplexShape.up в„•) Kp q).symm
    -- The section complex `n вҶҰ О“(W, f_* I^n) = О“(jвҒ»В№W, I^n)` is the image of the chosen
    -- injective resolution of `H` under the additive sections-over-`jвҒ»В№W` functor.
    have hcomplex : (GW.mapHomologicalComplex (ComplexShape.up в„•)).obj Kp
        = ((pushforwardSectionsFunctor j W).mapHomologicalComplex (ComplexShape.up в„•)).obj
            (injectiveResolution H).cocomplex :=
      rfl
    rw [hcomplex]
    -- `isoRightDerivedObj` recognises this homology as the `q`-th right derived sections
    -- functor `Rбө  О“(jвҒ»В№W, -)` applied to `H`, i.e. the absolute cohomology `Hбө (jвҒ»В№W, H)`.
    refine IsZero.of_iso ?_ ((injectiveResolution H).isoRightDerivedObj
      (pushforwardSectionsFunctor j W) q).symm
    -- The sections functor `О“(jвҒ»В№W, -)` (here `pushforwardSectionsFunctor j W`, which is
    -- definitionally `sectionsFunctor (j вҒ»В№бөҒ W)`) is corepresented by `jShriekOU (j вҒ»В№бөҒ W)`, so its
    -- `q`-th right derived functor agrees with that of `Hom(jShriekOU (j вҒ»В№бөҒ W), -)`.  This
    -- discharges the *geometric* corepresentability half of Bridge (1)/(2).
    refine IsZero.of_iso ?_ ((rightDerivedNatIso (sectionsFunctorCorepIso (j вҒ»В№бөҒ W)) q).app H)
    -- Bridge (1)/(2) HOMOLOGICAL remainder DISCHARGED: `isZero_coyoneda_rightDerived_of_forall_ext_eq_zero`
    -- (built above, axiom-clean) reduces the right-derived vanishing of `Hom(jShriekOU (jвҒ»В№W), -)` to
    -- the `Ext`-vanishing `вҲҖ e : Ext (jShriekOU (jвҒ»В№W)) H q, e = 0`.
    refine isZero_coyoneda_rightDerived_of_forall_ext_eq_zero (jShriekOU (j вҒ»В№бөҒ W)) H q hq ?_
    intro e
    -- RESIDUAL (Bridge (2) Serre vanishing, geometric transport).  This goal `e = 0` is exactly the
    -- conclusion of the assembled `ext_jShriekOU_eq_zero_of_specIso U U.isoSpec (j вҒ»В№бөҒ W) H q hq V'
    -- hV' hjt hqc e` (built above, axiom-clean), where `V'` is the affine image open of `jвҒ»В№W` in
    -- `Spec О“(U,вҠӨ)`.  The three remaining geometric facts are the only unbuilt pieces:
    --   вҖў `hV' : IsAffineOpen V'`        вҖ” `jвҒ»В№W` affine (affine morphism `j`) + image under the iso;
    --   вҖў `hjt : ОҰ(jShriekOU (jвҒ»В№W)) вү… jShriekOU V'`  вҖ” the `jShriekOU` transport iso
    --       (`pushforward_commutes_free`/`_sheafify` + `yoneda_transport_along_homeo`);
    --   вҖў `hqc : (ОҰ H).IsQuasicoherent`  вҖ” pushforward along an iso preserves quasi-coherence.
    -- `hV'` is discharged below; `hjt`/`hqc` are the two remaining geometric transport sub-lemmas.
    refine ext_jShriekOU_eq_zero_of_specIso U U.isoSpec (j вҒ»В№бөҒ W) H q hq
      (U.isoSpec.inv вҒ»В№бөҒ (j вҒ»В№бөҒ W)) ?hV' ?hjt ?hqc e
    -- `jвҒ»В№W` is affine (`j` is an affine morphism, `W` affine), and its image under the iso
    -- `U.isoSpec.inv` (= preimage along `U.isoSpec.inv`) is affine.
    case hV' => exact (hW.preimage j).preimage_of_isIso U.isoSpec.inv
    case hjt => exact jShriekOU_transport_along_iso U.isoSpec (j вҒ»В№бөҒ W)
    -- RESIDUAL `hqc : (ОҰ H).IsQuasicoherent` (ОҰ = pushforwardEquivOfIso U.isoSpec).
    -- REDUCED to the per-slice case by `pushforward_iso_qcoh_of_slice_qcoh` (above, axiom-clean):
    -- extracting `qcd : H.QuasicoherentData.{u}` from `hH`, it suffices to prove, for each cover
    -- member `i`, `((ОҰ H).over (U.isoSpec.inv вҒ»В№бөҒ qcd.X i)).IsQuasicoherent`.
    -- `hqc : (ОҰ H).IsQuasicoherent` (ОҰ = pushforwardEquivOfIso U.isoSpec): discharged in full by
    -- `pushforward_iso_preserves_qcoh` (the per-slice presentation-transport chain built above вҖ”
    -- `pushforwardSliceTwoAdjunction` + `pushforwardSlicePullbackIso` + `Presentation.map`/`ofIsIso`).
    case hqc => exact pushforward_iso_preserves_qcoh U.isoSpec H hH
  -- Since affine opens form a basis of `X`, every section of `Q` restricts to `0` on the
  -- affine opens contained in its domain, so `Q` is sectionwise locally zero and its
  -- sheafification vanishes.
  apply CategoryTheory.GrothendieckTopology.isZero_presheafToSheaf_of_sections_locally_zero
    (Opens.grothendieckTopology X) (Q := Q)
  intro U s
  refine вҹЁ{ arrows := fun {V} _ => вҲғ W : TopologicalSpace.Opens X,
              IsAffineOpen W вҲ§ V вүӨ W вҲ§ W вүӨ U,
            downward_closed := ?_ }, ?_, ?_вҹ©
  В· rintro V V' g вҹЁA, hA, hVA, hAUвҹ© h
    exact вҹЁA, hA, le_trans (leOfHom h) hVA, hAUвҹ©
  В· -- membership in the opens topology: every point of `U` has an affine basis neighbourhood
    intro x hx
    obtain вҹЁW, hWmem, hxW, hWUвҹ© :=
      (TopologicalSpace.Opens.isBasis_iff_nbhd.mp (Scheme.isBasis_affineOpens X)) hx
    exact вҹЁW, homOfLE hWU, вҹЁW, hWmem, le_refl W, hWUвҹ©, hxWвҹ©
  В· -- the restriction of `s` to a sieve member `V вүӨ A вүӨ U` (with `A` affine) factors through
    -- `Q.obj (op A) = 0`, hence vanishes.
    rintro V g вҹЁA, hA, hVA, hAUвҹ©
    haveI : Subsingleton (ToType (Q.obj (Opposite.op A))) :=
      AddCommGrpCat.subsingleton_of_isZero (hSec A hA)
    have hgfac : g.op = (homOfLE hAU).op вү« (homOfLE hVA).op := by
      rw [вҶҗ op_comp]; congr 1
    rw [hgfac, Q.map_comp, ConcreteCategory.comp_apply,
      Subsingleton.elim ((ConcreteCategory.hom (Q.map (homOfLE hAU).op)) s) 0, map_zero]

/-- **Composition formula for higher direct images across an open immersion** (pinned
declaration; blueprint `lem:open_immersion_pushforward_comp`, part (2); Stacks
`lemma-relative-affine-vanishing`).

Let `j : U вҶӘ X` be an open immersion of an affine open `U` into a separated scheme `X`,
and `f : X вҹ¶ S` any morphism. For every quasi-coherent `O_U`-module `H` and every `k вүҘ 0`:
```
  R^k f_*(j_* H) вү… R^k (f вҲҳ j)_* H.
```
Proof route: choose an injective resolution `H вҶ’ IвҖў` in `U.Modules`; apply `j_*`
degreewise to get an `f_*`-acyclic resolution `j_* IвҖў` of `j_* H`
(`higherDirectImage_openImmersion_acyclic` for `j_*`-acyclicity, extended to
`f_*`-acyclicity via the same Serre-vanishing argument on `U вҲ© fвҒ»В№V`); then
