variable {X Y : Scheme.{u}} (ПҶ : X вү… Y) (Ui : X.Opens)

/-- `Opens.map ПҶ.hom.base` is an equivalence (twin of `opensMapInvBase_isEquivalence`). -/
instance opensMapHomBase_isEquivalence : (Opens.map ПҶ.hom.base).IsEquivalence :=
  inferInstanceAs (Opens.mapMapIso (Scheme.forgetToTop.mapIso ПҶ)).functor.IsEquivalence

/-- The opens-equivalence `Opens X вүҢ Opens Y` induced by the scheme iso `ПҶ`.  Built from
`mapMapIso` so that its `functor` is (defeq) `Opens.map ПҶ.inv.base` and its `inverse` is (defeq)
`Opens.map ПҶ.hom.base` вҖ” both honest `Opens.map`s, with known continuity. -/
noncomputable def opensEquivOfIso : TopologicalSpace.Opens X вүҢ TopologicalSpace.Opens Y :=
  Opens.mapMapIso (Scheme.forgetToTop.mapIso ПҶ).symm

/-- The slice equivalence `Over Uбөў вүҢ Over Vбөў` (`Vбөў = ПҶ.invвҒ»В№бөҒ Uбөў`). -/
noncomputable def sliceOversEquiv :
    CategoryTheory.Over Ui вүҢ CategoryTheory.Over (ПҶ.inv вҒ»В№бөҒ Ui) :=
  CategoryTheory.Over.postEquiv Ui (opensEquivOfIso ПҶ)

/-- Continuity of the forward slice functor (it is `Over.post (Opens.map ПҶ.inv.base)`). -/
instance sliceOversEquiv_functor_isContinuous :
    (sliceOversEquiv ПҶ Ui).functor.IsContinuous
      ((Opens.grothendieckTopology X).over Ui)
      ((Opens.grothendieckTopology Y).over (ПҶ.inv вҒ»В№бөҒ Ui)) :=
  overPost_slice_isContinuous ПҶ Ui

/-- Continuity of the post-functor along the opens-equivalence inverse `(opensEquivOfIso ПҶ).inverse`
(defeq `Opens.map ПҶ.hom.base`), the first factor of the inverse slice functor.  Stated in the
`postEquiv`-native syntax (`Vбөў = (opensEquivOfIso ПҶ).functor.obj Uбөў`) so the composite below matches
the goal coming out of `Over.postEquiv_inverse`. -/
instance overPost_slice_inverse_isContinuous :
    (Over.post (X := (opensEquivOfIso ПҶ).functor.obj Ui) (opensEquivOfIso ПҶ).inverse).IsContinuous
      ((Opens.grothendieckTopology Y).over ((opensEquivOfIso ПҶ).functor.obj Ui))
      ((Opens.grothendieckTopology X).over
        ((opensEquivOfIso ПҶ).inverse.obj ((opensEquivOfIso ПҶ).functor.obj Ui))) :=
  Functor.isContinuous_of_coverPreserving
    (compatiblePreservingOfFlat _ _)
    (CoverPreserving.overPost ((opensEquivOfIso ПҶ).functor.obj Ui)
      (coverPreserving_opens_map ПҶ.hom.base))

/-- Continuity of the inverse slice functor `eqv.inverse = Over.post (Opens.map ПҶ.hom.base) вӢҷ
Over.map (unitIso.inv)`, the correction-carrying composite. -/
instance sliceOversEquiv_inverse_isContinuous :
    (sliceOversEquiv ПҶ Ui).inverse.IsContinuous
