      ((Opens.grothendieckTopology X).over Ui) := by
  have key : ((Over.post (X := (opensEquivOfIso ПҶ).functor.obj Ui) (opensEquivOfIso ПҶ).inverse).comp
      (Over.map ((opensEquivOfIso ПҶ).unitIso.inv.app Ui))).IsContinuous
      ((Opens.grothendieckTopology Y).over ((opensEquivOfIso ПҶ).functor.obj Ui))
      ((Opens.grothendieckTopology X).over Ui) :=
    @Functor.isContinuous_comp _ _ _ _ _ _
      (Over.post (X := (opensEquivOfIso ПҶ).functor.obj Ui) (opensEquivOfIso ПҶ).inverse)
      (Over.map ((opensEquivOfIso ПҶ).unitIso.inv.app Ui))
      ((Opens.grothendieckTopology Y).over ((opensEquivOfIso ПҶ).functor.obj Ui))
      ((Opens.grothendieckTopology X).over
        ((opensEquivOfIso ПҶ).inverse.obj ((opensEquivOfIso ПҶ).functor.obj Ui)))
      ((Opens.grothendieckTopology X).over Ui)
      (overPost_slice_inverse_isContinuous ПҶ Ui)
